  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&family=DM+Sans:wght@400;500;600&display=swap');

    :root {
        --primary: #279c75;
        --primary-light: #34b887;
        --primary-dark: #1a7a5c;
        --primary-glow: rgba(39, 156, 117, 0.12);
        --accent: #f0522a;
        --accent-warm: #ff8c42;
        --text-primary: #12110f;
        --text-secondary: #3d3a35;
        --text-tertiary: #7a756d;
        --text-caption: #a09990;
        --bg-primary: #fdfcfb;
        --bg-secondary: #f5f3f0;
        --bg-highlight: #edfaf4;
        --bg-card: #ffffff;
        --border: #e8e4de;
        --border-light: #f0ece6;
        --shadow-xs: 0 1px 2px rgba(18,17,15,0.04);
        --shadow-sm: 0 2px 8px rgba(18,17,15,0.06);
        --shadow-md: 0 8px 24px rgba(18,17,15,0.08);
        --shadow-lg: 0 24px 48px rgba(18,17,15,0.12);
        --shadow-xl: 0 40px 80px rgba(18,17,15,0.16);
        --radius-sm: 6px;
        --radius-md: 12px;
        --radius-lg: 20px;
        --font-display: 'Playfair Display', Georgia, serif;
        --font-body: 'Source Serif 4', Georgia, serif;
        --font-ui: 'DM Sans', system-ui, sans-serif;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
        scroll-behavior: smooth;
        font-size: 18px;
        -webkit-text-size-adjust: 100%;
    }

    body {
        font-family: var(--font-body);
        line-height: 1.85;
        background: var(--bg-primary);
        color: var(--text-primary);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
    }

    /* ── Reading progress bar ── */
    .progress-bar {
        position: fixed; top: 0; left: 0; height: 3px;
        background: linear-gradient(90deg, var(--primary-dark), var(--primary), var(--primary-light));
        width: 0%; z-index: 1000;
        transition: width 0.15s linear;
    }

    /* ── Top nav strip ── */
    .top-nav {
        position: sticky; top: 0; z-index: 100;
        background: rgba(253, 252, 251, 0.92);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border-light);
        padding: 0 24px;
        display: flex; align-items: center; justify-content: space-between;
        height: 56px;
    }

    .back-button {
        font-family: var(--font-ui);
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-tertiary);
        text-decoration: none;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 12px;
        border-radius: var(--radius-sm);
        transition: all 0.2s ease;
        letter-spacing: 0.01em;
    }
    .back-button:hover {
        color: var(--primary);
        background: var(--primary-glow);
        transform: translateX(-2px);
    }
    .back-button::before { content: '←'; font-size: 1rem; }

    .nav-brand {
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    /* ── Main layout ── */
    .page-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: 1fr 280px;
        grid-template-rows: auto;
        gap: 0 64px;
        align-items: start;
    }

    /* ── Hero header ── */
    .article-header {
        grid-column: 1 / -1;
        padding: 64px 0 48px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 56px;
        position: relative;
    }

    .article-header::after {
        content: '';
        position: absolute;
        bottom: -1px; left: 0;
        width: 80px; height: 3px;
        background: var(--primary);
        border-radius: 2px;
    }

    .category-badge {
        font-family: var(--font-ui);
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 14px;
        background: var(--bg-highlight);
        color: var(--primary-dark);
        border: 1px solid rgba(39, 156, 117, 0.2);
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 24px;
    }
    .category-badge::before { content: '✦'; font-size: 0.6rem; }

    h1 {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        font-weight: 800;
        line-height: 1.18;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        margin-bottom: 20px;
        max-width: 820px;
        word-wrap: break-word;
        overflow-wrap: break-word;
        hyphens: auto;
    }

    .h1-subtitle {
        font-family: var(--font-body);
        font-size: clamp(1.05rem, 2vw, 1.25rem);
        font-weight: 400;
        font-style: italic;
        color: var(--text-secondary);
        line-height: 1.55;
        max-width: 680px;
        margin-bottom: 36px;
    }

    /* ── Article meta strip ── */
    .article-meta {
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .author-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .author-avatar {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-light) 100%);
        display: flex; align-items: center; justify-content: center;
        color: white;
        font-family: var(--font-ui);
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.02em;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(39, 156, 117, 0.3);
    }

    .author-name {
        font-family: var(--font-ui);
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-primary);
        display: block;
    }

    .meta-items {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .meta-item {
        font-family: var(--font-ui);
        font-size: 0.78rem;
        color: var(--text-tertiary);
        display: flex;
        align-items: center;
        gap: 4px;
        font-weight: 500;
    }

    .meta-divider {
        width: 1px; height: 32px;
        background: var(--border);
        flex-shrink: 0;
    }

    /* ── Main content column ── */
    .content-column {
        min-width: 0;
        padding-bottom: 80px;
    }

    /* ── Sidebar ── */
    .sidebar {
        padding-top: 0;
        position: sticky;
        top: 72px;
        max-height: calc(100vh - 96px);
        overflow-y: auto;
        scrollbar-width: none;
    }
    .sidebar::-webkit-scrollbar { display: none; }

    /* ── Table of Contents ── */
    .table-of-contents {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 24px;
        margin-bottom: 24px;
    }

    .toc-title {
        font-family: var(--font-ui);
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .toc-title::before {
        content: '';
        display: inline-block;
        width: 16px; height: 2px;
        background: var(--primary);
        border-radius: 1px;
    }

    .table-of-contents ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .table-of-contents ul li {
        border-left: 2px solid var(--border-light);
        padding: 0;
        margin: 0;
        transition: border-color 0.2s;
    }

    .table-of-contents ul li:hover {
        border-left-color: var(--primary);
    }

    .table-of-contents ul li a {
        display: block;
        padding: 6px 12px;
        font-family: var(--font-ui);
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-decoration: none;
        line-height: 1.4;
        transition: color 0.2s;
        font-weight: 400;
    }

    .table-of-contents ul li a:hover {
        color: var(--primary);
    }

    /* ── Sidebar CTA card ── */
    .sidebar-cta {
        background: linear-gradient(145deg, var(--primary-dark), var(--primary));
        border-radius: var(--radius-md);
        padding: 24px;
        color: white;
        text-align: center;
    }

    .sidebar-cta h4 {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .sidebar-cta p {
        font-family: var(--font-ui);
        font-size: 0.8rem;
        opacity: 0.85;
        margin-bottom: 16px;
        line-height: 1.5;
        color: white;
    }

    .sidebar-cta a {
        display: inline-block;
        background: white;
        color: var(--primary-dark);
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 700;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        letter-spacing: 0.02em;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .sidebar-cta a:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

    /* ── Article typography ── */
    article {
        font-family: var(--font-body);
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text-secondary);
    }

    article h2 {
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2.5vw, 1.75rem);
        font-weight: 700;
        color: var(--text-primary);
        margin: 56px 0 20px;
        line-height: 1.25;
        letter-spacing: -0.015em;
        position: relative;
        padding-left: 20px;
    }

    article h2::before {
        content: '';
        position: absolute;
        left: 0; top: 50%;
        transform: translateY(-50%);
        width: 4px; height: 70%;
        background: var(--primary);
        border-radius: 2px;
    }

    article h3 {
        font-family: var(--font-display);
        font-size: clamp(1.1rem, 2vw, 1.35rem);
        font-weight: 700;
        color: var(--text-primary);
        margin: 40px 0 16px;
        line-height: 1.3;
        letter-spacing: -0.01em;
    }

    article h4 {
        font-family: var(--font-ui);
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 32px 0 12px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    article p {
        margin-bottom: 24px;
        color: var(--text-secondary);
    }

    article p:first-of-type {
        font-size: 1.08rem;
        color: var(--text-primary);
        font-weight: 400;
    }

    article a {
        color: var(--primary-dark);
        text-decoration: underline;
        text-decoration-color: rgba(39, 156, 117, 0.3);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.2s, color 0.2s;
    }
    article a:hover {
        color: var(--primary);
        text-decoration-color: var(--primary);
    }

    article ul, article ol {
        padding-left: 0;
        margin: 0 0 28px;
        list-style: none;
    }

    article ul li, article ol li {
        font-family: var(--font-body);
        position: relative;
        padding: 6px 0 6px 28px;
        color: var(--text-secondary);
        border-bottom: 1px solid var(--border-light);
    }
    article ul li:last-child, article ol li:last-child {
        border-bottom: none;
    }

    article ul li::before {
        content: '→';
        position: absolute; left: 0; top: 6px;
        color: var(--primary);
        font-weight: 600;
        font-family: var(--font-ui);
    }

    article ol {
        counter-reset: list-counter;
    }
    article ol li {
        counter-increment: list-counter;
    }
    article ol li::before {
        content: counter(list-counter);
        position: absolute; left: 0; top: 6px;
        width: 20px; height: 20px;
        background: var(--primary-glow);
        border: 1px solid rgba(39, 156, 117, 0.25);
        border-radius: 50%;
        color: var(--primary-dark);
        font-family: var(--font-ui);
        font-size: 0.72rem;
        font-weight: 700;
        display: flex; align-items: center; justify-content: center;
    }

    article blockquote {
        border-left: 3px solid var(--primary);
        background: var(--bg-highlight);
        margin: 40px 0;
        padding: 24px 28px;
        border-radius: 0 var(--radius-md) var(--radius-md) 0;
        position: relative;
    }

    article blockquote::before {
        content: '"';
        font-family: var(--font-display);
        font-size: 4rem;
        color: var(--primary-light);
        opacity: 0.3;
        position: absolute;
        top: -8px; left: 16px;
        line-height: 1;
    }

    article blockquote p {
        font-family: var(--font-display);
        font-style: italic;
        font-size: 1.1rem;
        color: var(--primary-dark);
        margin: 0;
        line-height: 1.6;
        position: relative;
        z-index: 1;
    }

    article strong {
        color: var(--text-primary);
        font-weight: 600;
    }

    article em {
        color: var(--primary-dark);
    }

    article code {
        font-family: 'SF Mono', 'Fira Code', monospace;
        font-size: 0.85em;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--accent);
    }

    article pre {
        background: #12110f;
        border-radius: var(--radius-md);
        padding: 24px;
        overflow-x: auto;
        margin: 32px 0;
    }

    article pre code {
        background: none;
        border: none;
        padding: 0;
        color: #e8e4de;
        font-size: 0.88rem;
    }

    /* ── Pull quote / highlight box ── */
    article .highlight-box {
        background: var(--bg-highlight);
        border: 1px solid rgba(39, 156, 117, 0.2);
        border-radius: var(--radius-md);
        padding: 24px 28px;
        margin: 40px 0;
    }

    /* ── Featured image (inside article body) ── */
    article figure {
        margin: 40px 0;
        text-align: center;
    }

    article figure img,
    .featured-image {
        width: 100%;
        height: auto;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-lg);
        display: block;
    }

    article figure figcaption {
        font-family: var(--font-ui);
        font-size: 0.78rem;
        color: var(--text-caption);
        margin-top: 10px;
        font-style: italic;
    }

    /* ── Tags ── */
    .tags-section {
        margin-top: 48px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
    }

    .tags-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .tag {
        font-family: var(--font-ui);
        font-size: 0.75rem;
        font-weight: 500;
        padding: 5px 12px;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-radius: 20px;
        color: var(--text-tertiary);
        transition: all 0.2s;
        cursor: default;
        letter-spacing: 0.02em;
    }
    .tag:hover {
        background: var(--primary-glow);
        border-color: rgba(39, 156, 117, 0.3);
        color: var(--primary-dark);
    }

    /* ── Share section ── */
    .share-section {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 36px;
        margin: 48px 0;
        text-align: center;
        box-shadow: var(--shadow-sm);
    }

    .share-section h3 {
        font-family: var(--font-display);
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .share-section p {
        font-family: var(--font-ui);
        font-size: 0.85rem;
        color: var(--text-tertiary);
        margin-bottom: 24px;
    }

    .share-buttons {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    .share-btn {
        height: 44px;
        padding: 0 20px;
        border-radius: 22px;
        border: none;
        color: white;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        display: inline-flex; align-items: center; justify-content: center;
        gap: 8px;
        font-family: var(--font-ui);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }
    .share-btn:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .share-btn.linkedin  { background: #0077b5; }
    .share-btn.facebook  { background: #1877f2; }
    .share-btn.whatsapp  { background: #25d366; }

    .share-label {
        display: inline;
    }

    /* ── Related posts / bottom CTA ── */
    .bottom-cta {
        background: linear-gradient(135deg, #0f5c40 0%, var(--primary) 60%, var(--primary-light) 100%);
        border-radius: var(--radius-lg);
        padding: 48px 40px;
        text-align: center;
        margin: 48px 0;
        color: white;
        position: relative;
        overflow: hidden;
    }

    .bottom-cta::before {
        content: '';
        position: absolute; inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .bottom-cta h3 {
        font-family: var(--font-display);
        font-size: clamp(1.3rem, 3vw, 1.8rem);
        font-weight: 800;
        margin-bottom: 12px;
        position: relative;
    }

    .bottom-cta p {
        font-family: var(--font-ui);
        font-size: 0.95rem;
        opacity: 0.85;
        margin-bottom: 28px;
        max-width: 480px;
        margin-left: auto; margin-right: auto;
        line-height: 1.6;
        position: relative;
    }

    .bottom-cta a {
        display: inline-block;
        background: white;
        color: var(--primary-dark);
        font-family: var(--font-ui);
        font-size: 0.9rem;
        font-weight: 700;
        padding: 14px 32px;
        border-radius: 10px;
        text-decoration: none;
        letter-spacing: 0.02em;
        position: relative;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .bottom-cta a:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.25);
    }

    /* ── Footer ── */
    footer {
        border-top: 1px solid var(--border);
        margin-top: 80px;
        padding: 40px 24px;
        text-align: center;
    }

    footer p {
        font-family: var(--font-ui);
        font-size: 0.82rem;
        color: var(--text-tertiary);
    }

    footer a {
        color: var(--primary);
        text-decoration: none;
        font-weight: 500;
    }
    footer a:hover { text-decoration: underline; }

    /* ── Animations ── */
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .article-header  { animation: fadeUp 0.5s ease both; }
    .content-column  { animation: fadeUp 0.5s 0.1s ease both; }
    .sidebar         { animation: fadeUp 0.5s 0.2s ease both; }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .page-wrapper {
            grid-template-columns: 1fr;
            gap: 0;
        }
        .sidebar {
            position: static;
            max-height: none;
            order: -1;
            margin-bottom: 32px;
        }
        .table-of-contents {
            display: none; /* hide TOC on mobile to reduce clutter */
        }
    }

    @media (max-width: 640px) {
        html { font-size: 16px; }
        .page-wrapper { padding: 0 16px; }
        .article-header { padding: 40px 0 32px; }
        h1 { font-size: 1.8rem; }
        .share-section { padding: 24px 20px; }
        .bottom-cta { padding: 36px 24px; }
        .share-label { display: none; }
    }

    /* ── Print ── */
    @media print {
        .progress-bar, .top-nav, .sidebar, .share-section, .bottom-cta { display: none; }
        .page-wrapper { grid-template-columns: 1fr; }
        body { font-size: 12pt; }
    }
    </style>
