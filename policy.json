{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowCloudFrontListAndGet",
            "Effect": "Allow",
            "Principal": {
                "Service": "cloudfront.amazonaws.com"
            },
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::thelivingdesk-blogs-313701249911-ap-south-1",
                "arn:aws:s3:::thelivingdesk-blogs-313701249911-ap-south-1/*"
            ],
            "Condition": {
                "ArnLike": {
                    "AWS:SourceArn": "arn:aws:cloudfront::313701249911:distribution/E2VEOTKXJIT56V"
                }
            }
        }
    ]
}