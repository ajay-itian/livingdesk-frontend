	 <style>
        /* Auto-sliding gallery animation */
        .gallery-container {
            position: relative;
            overflow: hidden;
        }
        .gallery-slide {
            display: flex;
            width: 1100%;
            animation: slide 25s linear;
        }
        .gallery-item {
            width: 5%;
            flex-shrink: 0;
        }
        @keyframes slide {
            0% { transform: translateX(0); }
            100% { transform: translateX(-95%); }
        }
    </style>


<script>
    document.addEventListener("DOMContentLoaded", function() {
        var phoneNumber = "917066002650"; // Replace with your WhatsApp number including country code
        var message = encodeURIComponent("Hello! I'm interested in your coworking space.");

        var whatsappLinks = document.querySelectorAll(".whatsapp-link");
        var userAgent = navigator.userAgent || navigator.vendor || window.opera;

        var whatsappURL = "https://web.whatsapp.com/send?phone=" + phoneNumber + "&text=" + message; // Default for desktop

        if (/android/i.test(userAgent)) {
            whatsappURL = "intent://send?phone=" + phoneNumber + "&text=" + message + "#Intent;scheme=whatsapp;package=com.whatsapp;end;";
        } else if (/iPhone|iPad|iPod/i.test(userAgent)) {
            whatsappURL = "whatsapp://send?phone=" + phoneNumber + "&text=" + message;
        }

        // Apply to all WhatsApp buttons
        whatsappLinks.forEach(function(link) {
            link.href = whatsappURL;
        });
    });
</script>


