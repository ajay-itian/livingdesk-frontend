Options -MultiViews
RewriteEngine On
RewriteBase /

# 1. Serve real files (JS, CSS, images, fonts, _next/, etc.) directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Serve real directories directly
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 3. For URLs WITHOUT trailing slash, serve folder/index.html if it exists
#    e.g. /blogs/some-slug → /blogs/some-slug/index.html
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
RewriteRule ^(.+[^/])$ /$1/index.html [L]

# 4. For trailing-slash URLs like /booking/ /blogs/ /community/ etc.
#    serve the pre-built index.html that Next.js generated
RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}index.html -f
RewriteRule ^(.+)/$ /$1/index.html [L]

# 5. For URLs WITHOUT trailing slash where no index.html folder exists
#    redirect to trailing slash (Next.js trailingSlash: true)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# 6. Custom 404 page (Next.js generates this automatically)
ErrorDocument 404 /404/index.html
